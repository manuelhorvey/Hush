# Hush local development environment

APP_ENV=local
LOG_LEVEL=info

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8080

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hush
POSTGRES_USER=hush
POSTGRES_PASSWORD=hush_local_password
DATABASE_URL=postgres://hush:hush_local_password@localhost:5432/hush

REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222
